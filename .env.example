NODE_ENV=development
PORT=3000

# Keep true until real Feishu CLI commands are calibrated.
FEISHU_DRY_RUN=true
# Keep true unless you are only verifying real confirmation-card delivery.
FEISHU_CARD_SEND_DRY_RUN=true
LARK_CLI_BIN=lark-cli

# 飞书开放平台 -> 应用 -> 事件订阅 -> 加密策略：Verification Token
LARK_VERIFICATION_TOKEN=
# 飞书开放平台 -> 应用 -> 事件订阅 -> 加密策略：Encrypt Key（后续解密使用）
LARK_ENCRYPT_KEY=
# 飞书开放平台 -> 应用 -> 卡片 -> 消息卡片请求地址，填写: https://your-domain/webhooks/feishu/card-action
LARK_CARD_CALLBACK_URL_HINT=

# Use a dedicated DB for real-LLM experiments if needed.
SQLITE_PATH=./data/meeting-atlas.db

# LLM provider:
# - mock: stable local fixtures, used by tests and default demo
# - openai-compatible: real model via OpenAI-compatible Chat Completions API
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional LLM runtime controls
LLM_TIMEOUT_MS=60000
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096
LLM_DEBUG_RAW=false
