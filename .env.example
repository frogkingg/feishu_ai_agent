# 不要把真实 Key 提交或发到聊天里；在本地复制为 .env 后填写。
# 兼容 OpenAI-style API。DeepSeek 可填 deepseek API Key，火山方舟也继续可用。
OPENAI_API_KEY=your-openai-compatible-api-key

# OpenAI-compatible chat completions 请求地址。
# DeepSeek 示例：https://api.deepseek.com/chat/completions
# 火山方舟示例：https://ark.cn-beijing.volces.com/api/v3/chat/completions
OPENAI_API_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# 模型名或供应商 endpoint ID。
# DeepSeek 示例：deepseek-chat
# 火山方舟示例：ep-20260423223104-568xj
OPENAI_MODEL=ep-20260423223104-568xj

# 可选：大模型超时和飞书单条回复长度保护。
LLM_TIMEOUT_MS=20000
LLM_MAX_REPLY_CHARS=1800

# 可选：事件订阅没有推送时，定时轮询这些会话的新消息；多个 chat_id 用逗号分隔。
LARK_POLL_CHAT_IDS=
LARK_POLL_INTERVAL_MS=5000
