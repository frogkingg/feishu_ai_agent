NODE_ENV=development
PORT=3000

# Mode A (default): full dry-run, no real card send and no real Feishu writes.
FEISHU_DRY_RUN=true
# Mode B: keep FEISHU_DRY_RUN=true and set this to false to send real confirmation cards only.
# Mode C: FEISHU_DRY_RUN=false is future full real mode and is not recommended yet.
FEISHU_CARD_SEND_DRY_RUN=true
LARK_CLI_BIN=lark-cli

# Use a dedicated DB for real-LLM experiments if needed.
SQLITE_PATH=./data/meeting-atlas.db

# LLM provider:
# - mock: stable local fixtures, used by tests and default demo
# - openai-compatible: real model via OpenAI-compatible Chat Completions API
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional LLM runtime controls
LLM_TIMEOUT_MS=60000
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096
LLM_DEBUG_RAW=false
