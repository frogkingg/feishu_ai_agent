NODE_ENV=development
PORT=3000

# Mode A (default commit/demo mode): full dry-run, no real card send and no real Feishu writes.
FEISHU_DRY_RUN=true
# Optional read-only canary: keep FEISHU_DRY_RUN=true and set this to false to fetch real Feishu meeting notes/transcripts.
FEISHU_READ_DRY_RUN=true
# Mode B: keep FEISHU_DRY_RUN=true and set this to false to send real confirmation cards only.
# Mode C: isolated real-write canary only. Do not enable by default for shared commit/demo runs.
# For Mode C, use a dedicated DB/workspace/recipient, then open one workflow at a time or a full canary after CLI readiness.
# CLI failures must fail the confirmation path; never record real Feishu writes as successful without a successful CLI result.
FEISHU_CARD_SEND_DRY_RUN=true
# Real confirmation cards must be clickable. Set false only for explicit preview-only display tests.
FEISHU_CARD_ACTIONS_ENABLED=true
# Per-workflow canaries: default to FEISHU_DRY_RUN. Keep the committed defaults dry-run and disable exactly one only inside an isolated canary.
FEISHU_TASK_CREATE_DRY_RUN=true
FEISHU_CALENDAR_CREATE_DRY_RUN=true
FEISHU_KNOWLEDGE_WRITE_DRY_RUN=true
LARK_CLI_BIN=lark-cli

# 飞书开放平台 -> 应用 -> 事件订阅 -> 加密策略：Verification Token
LARK_VERIFICATION_TOKEN=
# 飞书开放平台 -> 应用 -> 事件订阅 -> 加密策略：Encrypt Key（后续解密使用）
LARK_ENCRYPT_KEY=
# 飞书开放平台 -> 应用 -> 卡片 -> 消息卡片请求地址，必须和这里一致，且不能是 localhost/127.0.0.1。
# 示例: https://your-domain/webhooks/feishu/card-action
LARK_CARD_CALLBACK_URL_HINT=
# 可选：保护本地 /dev/* 调试接口；配置后请求必须带 header: x-dev-api-key。
DEV_API_KEY=

# Use a dedicated DB for real-LLM experiments if needed.
SQLITE_PATH=./data/meeting-atlas.db

# LLM provider:
# - mock: stable local fixtures, used by tests and default demo
# - openai-compatible: real model via OpenAI-compatible Chat Completions API
LLM_PROVIDER=mock
LLM_BASE_URL=
LLM_API_KEY=
LLM_MODEL=

# Optional LLM runtime controls
LLM_TIMEOUT_MS=30000
LLM_MAX_INPUT_CHARS=30000
LLM_TEMPERATURE=0
LLM_MAX_TOKENS=4096
LLM_DEBUG_RAW=false

# Optional prompt override for temporary dist/runtime packages.
MEETINGATLAS_PROMPT_DIR=
