{
  "name": "project-pilot",
  "version": "1.0.0",
  "description": "飞书项目管理专家Agent",
  "main": "dist/index.js",
  "scripts": {
    "dev": "ts-node src/index.ts",
    "prestart": "npm run build",
    "start": "node dist/index.js",
    "build": "tsc",
    "bot:daemon": "npm run bot:install",
    "bot:status": "sh scripts/status.sh",
    "bot:stop": "sh scripts/stop.sh",
    "bot:log": "tail -f .runtime/project-pilot.log .runtime/project-pilot.launchd.log .runtime/project-pilot.launchd.err.log",
    "bot:install": "sh scripts/install-launch-agent.sh",
    "bot:uninstall": "sh scripts/stop.sh",
    "bot:doctor": "sh scripts/doctor.sh",
    "deploy:local": "sh scripts/deploy-local.sh"
  },
  "keywords": [],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.0.0"
  }
}
